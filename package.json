{
  "name": "ghostlog",
  "displayName": "GhostLog",
  "description": "Inline console.log value display - free ConsoleNinja alternative",
  "version": "0.2.0",
  "publisher": "bkmashiro",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onView:ghostlog.logViewer",
    "onView:ghostlog.repl",
    "onCommand:ghostlog.addLogpoint",
    "onCommand:ghostlog.addLens",
    "onCommand:ghostlog.editLens",
    "onCommand:ghostlog.removeLens",
    "onCommand:ghostlog.pinPath",
    "onCommand:ghostlog.snapshotLogs",
    "onCommand:ghostlog.diffLogs",
    "onCommand:ghostlog.startMcp",
    "onCommand:ghostlog.stopMcp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghostlog.clear",
        "title": "GhostLog: Clear All Inline Values"
      },
      {
        "command": "ghostlog.toggle",
        "title": "GhostLog: Toggle Inline Display"
      },
      {
        "command": "ghostlog.clearFile",
        "title": "GhostLog: Clear This File"
      },
      {
        "command": "ghostlog.addLogpoint",
        "title": "GhostLog: Add Logpoint Here"
      },
      {
        "command": "ghostlog.addLens",
        "title": "GhostLog: Add Lens to This Line"
      },
      {
        "command": "ghostlog.editLens",
        "title": "GhostLog: Edit Lens Expression"
      },
      {
        "command": "ghostlog.removeLens",
        "title": "GhostLog: Remove Lens from This Line"
      },
      {
        "command": "ghostlog.pinPath",
        "title": "GhostLog: Pin Path"
      },
      {
        "command": "ghostlog.snapshotLogs",
        "title": "GhostLog: Snapshot Current Logs"
      },
      {
        "command": "ghostlog.diffLogs",
        "title": "GhostLog: Diff with Last Snapshot"
      },
      {
        "command": "ghostlog.startMcp",
        "title": "GhostLog: Start MCP Server"
      },
      {
        "command": "ghostlog.stopMcp",
        "title": "GhostLog: Stop MCP Server"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ghostlog",
          "title": "GhostLog",
          "icon": "media/ghostlog.svg"
        }
      ]
    },
    "views": {
      "ghostlog": [
        {
          "id": "ghostlog.logViewer",
          "name": "Log Viewer",
          "type": "webview"
        },
        {
          "id": "ghostlog.repl",
          "name": "REPL",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "GhostLog",
      "properties": {
        "ghostlog.deltaCapacity": {
          "type": "number",
          "default": 200,
          "description": "Max delta entries to store per log line"
        },
        "ghostlog.maxValueKB": {
          "type": "number",
          "default": 10,
          "description": "Max KB to store full value (larger values stored as preview)"
        },
        "ghostlog.uiDebounceMs": {
          "type": "number",
          "default": 200,
          "description": "Decoration update debounce in ms"
        },
        "ghostlog.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable inline display"
        },
        "ghostlog.mcpEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the GhostLog MCP server"
        },
        "ghostlog.mcpPort": {
          "type": "number",
          "default": 5678,
          "description": "Port for the GhostLog MCP server"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js --format=cjs",
    "test": "tsx --test test/**/*.test.ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  }
}
